{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/eslint-config"
	},
	"name": "@picus/eslint-config",
	"version": "4.0.434",
	"description": "Default configuration for Picus templates (ESLint <= 8)",
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"lint": "eslint src",
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"make": "tsgo -d"
	},
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"license": "ISC",
	"dependencies": {},
	"peerDependencies": {
		"eslint": ">=7.15.0"
	},
	"devDependencies": {
		"@picus/eslint-plugin": "workspace:*",
		"@typescript-eslint/eslint-plugin": "6.21.0",
		"@typescript-eslint/parser": "6.21.0",
		"eslint-plugin-react": "7.37.4",
		"eslint-plugin-react-hooks": "4.6.0",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"ffmpeg",
		"video",
		"react",
		"player"
