{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/enable-scss"
	},
	"name": "@picus/enable-scss",
	"version": "4.0.434",
	"description": "Enable SCSS support in Picus",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts",
		"formatting": "oxfmt src --check",
		"format": "oxfmt src"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"style-loader": "4.0.0",
		"css-loader": "5.2.7",
		"sass-loader": "14.2.1"
	},
	"peerDependencies": {
		"@picus/bundler": "workspace:*"
	},
	"devDependencies": {
		"@picus/bundler": "workspace:*",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"tailwind"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		}
	},
	"homepage": "https://www.picus.dev/docs/enable-scss/overview"
}
