{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/skia"
	},
	"name": "@picus/skia",
	"version": "4.0.434",
	"description": "Include React Native Skia components in a Picus video",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"author": "Jonny Burger <jonny@picus.dev>, William Candillon <wcandillon@gmail.com>",
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"picus": "workspace:*"
	},
	"peerDependencies": {
		"@shopify/react-native-skia": ">=0.1.191",
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0"
	},
	"devDependencies": {
		"@picus/bundler": "workspace:*",
		"@shopify/react-native-skia": "2.0.0",
		"canvaskit-wasm": "0.40.0",
		"@types/react-native": "^0.69.2",
		"react": "catalog:",
		"react-dom": "catalog:",
		"picus": "workspace:*",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"skia"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		},
		"./enable": {
			"types": "./dist/cjs/enable.d.ts",
			"module": "./dist/esm/enable.mjs",
			"import": "./dist/esm/enable.mjs",
			"require": "./dist/cjs/enable.js"
		}
	},
	"typesVersions": {
		">=1.0": {
			"enable": [
				"dist/cjs/enable.d.ts"
			]
		}
	},
	"homepage": "https://www.picus.dev/docs/skia"
}
