{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/rounded-text-box"
	},
	"name": "@picus/rounded-text-box",
	"version": "4.0.434",
	"description": "Create a TikTok-like multiline text box SVG path with rounded corners",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"require": "./dist/cjs/index.js",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		}
	},
	"dependencies": {
		"@picus/layout-utils": "workspace:*",
		"@picus/paths": "workspace:*"
	},
	"devDependencies": {
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"maintainers": [
		"Jonny Burger <jonny@picus.dev>"
	],
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"keywords": [
		"picus",
		"svg"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/rounded-text-box"
}
