{
	"name": "@picus/animated-emoji",
	"version": "4.0.434",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		}
	},
	"author": "Yehor Misiats (https://github.com/satelllte)",
	"maintainers": [
		"Jonny Burger <jonny@picus.dev>"
	],
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"picus": "workspace:*"
	},
	"keywords": [],
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/animated-emoji"
	},
	"homepage": "https://www.picus.dev/docs/animated-emoji",
	"description": "Google Fonts Animated Emojis as Picus components",
	"devDependencies": {
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	}
}
