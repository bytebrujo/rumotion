{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/eslint-plugin"
	},
	"name": "@picus/eslint-plugin",
	"version": "4.0.434",
	"description": "Rules for writing Picus code",
	"scripts": {
		"test": "node src/tests/execute.mjs",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"main": "dist/index.js",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"license": "ISC",
	"dependencies": {
		"@typescript-eslint/utils": "5.19.0"
	},
	"keywords": [
		"eslint",
		"eslintplugin"
	],
	"peerDependencies": {
		"eslint": ">=7.0.0"
	},
	"devDependencies": {
		"vitest": "catalog:",
		"eslint": "8.57.0",
		"@typescript/native-preview": "catalog:"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/cjs/index.js",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		}
	},
	"private": false,
	"homepage": "https://www.picus.dev/docs/brownfield#install-the-eslint-plugin"
}
