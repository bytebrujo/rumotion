	"author": "Jonny Burger",
	"main": "dist/index.js",
	"files": [
		"dist"
	],
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"dev": "picus studio --props src/my-props.json",
		"start-bun": "PATCH_BUN_DEVELOPMENT=true bun --bun picus studio",
		"start-js": "picus preview src/entry.jsx",
		"comps": "picus compositions",
		"clean": "rm -rf build && rm -rf out",
		"lint": "eslint src",
		"test": "tsc && bun test src --timeout 60000",
		"render": "picus render react-svg",
		"bundle": "picus bundle",
		"render-js": "picus render src/entry.jsx framer",
		"render-gif": "picus render framer out/video.gif --codec=gif --every-nth-frame=2",
		"render-transparent": "picus render --image-format=png --pixel-format=yuva420p --codec=vp8 react-svg out/video.webm"
	},
