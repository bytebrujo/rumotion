{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/fonts"
	},
	"name": "@picus/fonts",
	"version": "4.0.434",
	"description": "Helpers for loading local fonts into Picus",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"keywords": [
		"picus",
		"fonts"
	],
	"author": "Lucas Benya <bitup.games@gmail.com>",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"picus": "workspace:*"
	},
	"devDependencies": {
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/fonts-api"
}
