{
	"name": "@picus/zod-types-v3",
	"version": "4.0.434",
	"description": "Zod 3.22.3 types for Picus",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"module": "dist/esm/index.mjs",
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/zod-types-v3"
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"watch": "tsgo -w",
		"make": "tsgo && bun --env-file=../.env.bundle bundle.ts"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"picus": "workspace:*",
		"@picus/zod-types": "workspace:*"
	},
	"peerDependencies": {
		"zod": ">=3.0.0 <4.0.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"devDependencies": {
		"zod": "3.22.3",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"zod",
		"zod-v3"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/zod-types/v3"
}
