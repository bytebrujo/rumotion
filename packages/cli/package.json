{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/cli"
	},
	"name": "@picus/cli",
	"version": "4.0.434",
	"description": "Control Picus features using the `npx picus` command",
	"main": "dist/index.js",
	"sideEffects": false,
	"bin": {
		"picus": "picus-cli.js",
		"picusb": "picusb-cli.js",
		"picusd": "picusd-cli.js"
	},
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"test": "bun test src",
		"make": "tsgo -d"
	},
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"exports": {
		".": "./dist/index.js",
		"./config": "./dist/config/index.js",
		"./package.json": "./package.json"
	},
	"typesVersions": {
		">=1.0": {
			"config": [
				"dist/config/index.d.ts"
			]
		}
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"license": "SEE LICENSE IN LICENSE.md",
	"dependencies": {
		"@picus/bundler": "workspace:*",
		"@picus/media-utils": "workspace:*",
		"@picus/player": "workspace:*",
		"@picus/renderer": "workspace:*",
		"@picus/studio-shared": "workspace:*",
		"@picus/studio-server": "workspace:*",
		"@picus/studio": "workspace:*",
		"dotenv": "17.3.1",
		"minimist": "1.2.6",
		"prompts": "2.4.2",
		"picus": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0"
	},
	"devDependencies": {
		"@types/minimist": "^1.2.2",
		"@types/prompts": "^2.4.1",
		"@types/prettier": "^2.7.2",
		"@types/node": "catalog:",
		"@picus/zod-types": "workspace:*",
		"@picus/tailwind-v4": "workspace:*",
		"@picus/enable-scss": "workspace:*",
		"@picus/skia": "workspace:*",
		"react": "catalog:",
		"react-dom": "catalog:",
		"zod": "catalog:",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"ffmpeg",
		"video",
		"react",
		"player"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/cli"
}
