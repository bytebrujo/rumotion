{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/bundler"
	},
	"name": "@picus/bundler",
	"version": "4.0.434",
	"description": "Bundle Picus compositions using Webpack",
	"main": "dist/index.js",
	"sideEffects": false,
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"test": "bun test src",
		"make": "tsgo -d"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"license": "SEE LICENSE IN LICENSE.md",
	"dependencies": {
		"@rspack/core": "1.7.6",
		"@rspack/plugin-react-refresh": "1.6.1",
		"css-loader": "5.2.7",
		"esbuild": "0.25.0",
		"react-refresh": "0.18.0",
		"picus": "workspace:*",
		"@picus/studio": "workspace:*",
		"@picus/studio-shared": "workspace:*",
		"@picus/media-parser": "workspace:*",
		"style-loader": "4.0.0",
		"source-map": "0.7.3",
		"webpack": "5.105.0"
	},
	"peerDependencies": {
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0"
	},
	"devDependencies": {
		"react": "catalog:",
		"react-dom": "catalog:",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"ffmpeg",
		"video",
		"react",
		"webpack",
		"player"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/bundler"
}
