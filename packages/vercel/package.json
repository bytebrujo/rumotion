{
	"name": "@picus/vercel",
	"version": "4.0.434",
	"description": "Render Picus videos on Vercel Sandbox",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"module": "dist/esm/index.mjs",
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/vercel"
	},
	"sideEffects": false,
	"type": "module",
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"watch": "tsgo -w",
		"make": "bun --env-file=../.env.bundle bundle.ts && tsgo"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"contributors": [],
	"license": "Picus License",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"@picus/renderer": "workspace:*",
		"picus": "workspace:*"
	},
	"peerDependencies": {
		"@vercel/sandbox": ">=1.0.0"
	},
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		},
		"./package.json": "./package.json"
	},
	"devDependencies": {
		"@picus/eslint-config-internal": "workspace:*",
		"@vercel/blob": "2.3.0",
		"@vercel/sandbox": "1.6.0",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"vercel",
		"sandbox",
		"video"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/vercel/api"
}
