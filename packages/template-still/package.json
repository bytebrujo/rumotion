{
  "name": "template-still",
  "version": "1.0.0",
  "description": "A template for designing still images with dynamic data with built-in server for deploying to the cloud.",
  "scripts": {
    "start": "node dist/server/index.js",
    "make": "tsc -d",
    "dev": "picus studio",
    "build": "picus bundle",
    "render": "picus still PreviewCard out/still.png",
    "upgrade": "picus upgrade",
    "server": "bun src/server/index.ts",
    "lint": "eslint src && tsc"
  },
  "repository": {},
  "license": "UNLICENSED",
  "dependencies": {
    "@aws-sdk/client-s3": "3.986.0",
    "@picus/bundler": "workspace:*",
    "@picus/cli": "workspace:*",
    "@picus/renderer": "workspace:*",
    "@picus/zod-types": "workspace:*",
    "@types/express": "4.17.13",
    "@types/express-rate-limit": "5.1.3",
    "@types/node": "20.12.14",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "dotenv": "17.3.1",
    "express": "4.21.0",
    "express-rate-limit": "5.3.0",
    "p-limit": "3.1.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "picus": "workspace:*",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@picus/eslint-config-flat": "workspace:*",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "bun": "1.3.3",
    "typescript": "5.9.3"
  },
  "private": true
}
