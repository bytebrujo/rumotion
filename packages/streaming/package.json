{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/streaming"
	},
	"name": "@picus/streaming",
	"version": "4.0.434",
	"description": "Utilities for streaming data between programs",
	"main": "dist",
	"sideEffects": false,
	"scripts": {
		"lint": "eslint src",
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/index.js",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs"
		}
	}
}
