{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/player"
	},
	"name": "@picus/player",
	"version": "4.0.434",
	"description": "React component for embedding a Picus preview into your app",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun ensure-correct-version.ts && bun --env-file=../.env.bundle bundle.ts",
		"test": "bun test src",
		"prerelease": "cp ../../README.md ."
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		}
	},
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"author": "Jonny Burger <jonny@picus.dev>",
	"maintainers": [
		"Jonny Burger <jonny@picus.dev>",
		"Shankhadeep Dey <shankhadeepdey99@gmail.com>"
	],
	"license": "SEE LICENSE IN LICENSE.md",
	"dependencies": {
		"picus": "workspace:*"
	},
	"peerDependencies": {
		"react": ">=16.8.0",
		"react-dom": ">=16.8.0"
	},
	"devDependencies": {
		"@testing-library/react": "16.1.0",
		"@happy-dom/global-registrator": "14.5.1",
		"csstype": "^3.1.1",
		"react": "catalog:",
		"react-dom": "catalog:",
		"webpack": "5.105.0",
		"zod": "catalog:",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"picus",
		"ffmpeg",
		"video",
		"react",
		"player"
	],
	"publishConfig": {
		"access": "public"
	},
	"homepage": "https://www.picus.dev/docs/player"
}
