{
	"repository": {
		"url": "https://github.com/picus-dev/picus/tree/main/packages/zod-types"
	},
	"name": "@picus/zod-types",
	"version": "4.0.434",
	"description": "Zod types for Picus",
	"main": "dist/cjs/index.js",
	"types": "dist/cjs/index.d.ts",
	"module": "dist/esm/index.mjs",
	"sideEffects": false,
	"scripts": {
		"formatting": "oxfmt src --check",
		"format": "oxfmt src",
		"lint": "eslint src",
		"make": "tsgo -d && bun --env-file=../.env.bundle bundle.ts"
	},
	"author": "Jonny Burger",
	"contributors": [],
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/picus-dev/picus/issues"
	},
	"dependencies": {
		"picus": "workspace:*"
	},
	"peerDependencies": {
		"zod": "catalog:"
	},
	"devDependencies": {
		"zod": "catalog:",
		"@picus/eslint-config-internal": "workspace:*",
		"eslint": "catalog:",
		"@typescript/native-preview": "catalog:"
	},
	"keywords": [
		"zod",
		"color",
		"picus"
	],
	"publishConfig": {
		"access": "public"
	},
	"exports": {
		"./package.json": "./package.json",
		".": {
			"types": "./dist/cjs/index.d.ts",
			"module": "./dist/esm/index.mjs",
			"import": "./dist/esm/index.mjs",
			"require": "./dist/cjs/index.js"
		}
	},
	"homepage": "https://www.picus.dev/docs/zod-types"
}
