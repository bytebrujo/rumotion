{
	"$schema": "https://turbo.build/schema.json",
	"ui": "stream",
	"globalEnv": ["ENABLE_EXPERIMENTAL_COREPACK"],
	"tasks": {
		"formatting": {
			"dependsOn": [],
			"outputLogs": "new-only"
		},
		"publishprivate": {
			"dependsOn": [],
			"outputLogs": "new-only"
		},
		"clean": {},
		"testssr": {
			"dependsOn": ["^make", "@picus/example#bundle"]
		},
		"testlambda": {
			"dependsOn": ["^make", "@picus/example#bundle"]
		},
		"testwebcodecs": {
			"dependsOn": ["@picus/webcodecs#make"]
		},
		"testwebrenderer": {
			"dependsOn": ["@picus/web-renderer#make"]
		},
		"build": {
			"dependsOn": ["^make"],
			"outputs": ["dist"],
			"outputLogs": "new-only"
		},
		"make": {
			"dependsOn": ["^make"],
			"outputs": ["dist"],
			"outputLogs": "new-only"
		},
		"@picus/example#bundle": {
			"dependsOn": ["^make", "make"],
			"outputs": ["build", "./node_modules/.cache"],
			"outputLogs": "new-only"
		},
		"@picus/example#test": {
			"dependsOn": ["@picus/example#bundle"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"build-docs": {
			"dependsOn": ["^make", "make", "@picus/convert#build-spa", "@picus/brand#bundle"],
			"outputs": [".docusaurus", "build", "node_modules/.cache/twoslash"],
			"outputLogs": "new-only"
		},
		"test": {
			"dependsOn": ["^make", "make"],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"@picus/renderer#test": {
			"dependsOn": [
				"^make",
				"make",
				"@picus/lambda#make",
				"@picus/it-tests#test",
				"@picus/example#bundle"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"lint": {
			"dependsOn": [
				"@picus/eslint-config-internal#make",
				"@picus/eslint-config#make",
				"^make"
			],
			"outputs": [],
			"outputLogs": "new-only"
		},
		"@picus/google-fonts#make": {
			"outputs": ["src", ".cache-css", "dist"],
			"dependsOn": ["^make"],
			"outputLogs": "new-only"
		},
		"@picus/fig-autocomplete#make": {
			"outputs": ["src"],
			"dependsOn": ["^make"],
			"outputLogs": "new-only"
		},
		"@picus/cloudrun#make": {
			"dependsOn": ["^make"],
			"outputs": ["dist", "container/dist", "gcpInstaller/gcpInstaller.tar"],
			"outputLogs": "new-only"
		},
		"@picus/compositor#make": {
			"outputs": ["target/debug/build", "target/release/build"],
			"outputLogs": "new-only"
		},
		"@picus/it-tests#test": {
			"dependsOn": [
				"^make",
				"@picus/studio#make",
				"@picus/example#bundle"
			],
			"outputLogs": "new-only"
		},
		"@picus/convert#build-page": {
			"dependsOn": ["make", "^make"],
			"outputs": ["build", ".vercel"],
			"outputLogs": "new-only"
		},
		"@picus/convert#build-spa": {
			"dependsOn": ["make", "^make"],
			"outputs": ["spa-dist"],
			"outputLogs": "new-only"
		},
		"@picus/brand#bundle": {
			"dependsOn": ["^make"],
			"inputs": ["src/**", "public/**", "picus.config.*", "package.json", "tsconfig.json"],
			"outputs": ["build"],
			"outputLogs": "new-only"
		}
	}
}
